# This is a sample file. The backend does not read this file directly.
# To use a real API key, rename or copy this file to `.env`.

# Gemini API key from Google AI Studio.
GEMINI_API_KEY=replace_with_your_gemini_api_key

# Optional. auto uses Gemini when GEMINI_API_KEY exists, otherwise MockGenerator.
AI_PROVIDER=auto

# Optional. Keep the default unless you know you need another model.
GEMINI_MODEL=gemini-2.5-flash

# Optional. Used automatically if the main model is temporarily unavailable.
GEMINI_FALLBACK_MODEL=gemini-flash-lite-latest
